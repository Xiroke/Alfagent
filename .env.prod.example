# Copy to .env.prod and fill in secrets before:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# HTTPS (Let's Encrypt): set DOMAIN to a real hostname (DNS → this server)
# and LETSENCRYPT_EMAIL. Ports 80 and 443 must be reachable from the internet.
# Optional dry-run: LETSENCRYPT_STAGING=1
# Force re-issue: ./scripts/init-letsencrypt.sh --force

HTTP_PORT=80
HTTPS_PORT=443

DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_STAGING=0

POSTGRES_DB=alfagent
POSTGRES_USER=alfagent
POSTGRES_PASSWORD=change-me-strong-db-password

SECRET_KEY=change-me-to-a-long-random-secret-key

# Cloud.ru Foundation Models
API_KEY=

LLM_BASE_URL=https://foundation-models.api.cloud.ru/v1
LLM_CHAT_MODEL=ai-sage/GigaChat3-10B-A1.8B
LLM_CLASSIFIER_MODEL=ai-sage/GigaChat3-10B-A1.8B
LLM_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=2500

RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.35
EMBEDDING_DIMENSIONS=1024

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
UVICORN_WORKERS=2
ACCESS_TOKEN_EXPIRE_MINUTES=60
