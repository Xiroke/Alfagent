APP_NAME=Alfagent
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# PostgreSQL (asyncpg)
DATABASE_URL=postgresql+asyncpg://alfagent:alfagent@localhost:5432/alfagent
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# Security (placeholder)
SECRET_KEY=change-me-in-production-32chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_CLASSIFIER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_HTTP_REFERER=https://alfagent.local
OPENROUTER_APP_TITLE=Alfagent
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_CONNECT_TIMEOUT_SECONDS=10
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_BACKOFF_SECONDS=0.75

# RAG
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.35
EMBEDDING_DIMENSIONS=1536
