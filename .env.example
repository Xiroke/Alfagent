APP_NAME=Alfagent
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# PostgreSQL (asyncpg)
DATABASE_URL=postgresql+asyncpg://alfagent:alfagent@localhost:5432/alfagent
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# Security (placeholder)
SECRET_KEY=change-me-in-production-32chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cloud.ru Foundation Models (OpenAI-compatible)
API_KEY=
LLM_BASE_URL=https://foundation-models.api.cloud.ru/v1
LLM_CHAT_MODEL=ai-sage/GigaChat3-10B-A1.8B
LLM_CLASSIFIER_MODEL=ai-sage/GigaChat3-10B-A1.8B
LLM_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
LLM_TIMEOUT_SECONDS=60
LLM_CONNECT_TIMEOUT_SECONDS=10
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=0.75
LLM_TEMPERATURE=0.5
LLM_TOP_P=0.95
LLM_PRESENCE_PENALTY=0
LLM_MAX_TOKENS=2500

# RAG (Qwen3-Embedding-0.6B → 1024 dims)
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.35
EMBEDDING_DIMENSIONS=1024
